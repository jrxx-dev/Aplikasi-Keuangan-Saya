# ============================================
# 🤖 Telegram Bot - .gitignore
# ============================================

# ---- Dependencies ----
node_modules/

# ---- Environment Variables ----
.env
.env.local
.env*.local
!.env.example

# ---- TypeScript Compiled ----
dist/
*.js.map
*.tsbuildinfo

# ---- Sensitive / Runtime Data ----
webhook.json
webhook_info.json

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
