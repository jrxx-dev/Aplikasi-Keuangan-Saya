# ============================================
# 💰 Financemy Workspace - Root .gitignore
# ============================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Environment Variables (CRITICAL) ----
# Never commit .env files with real credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Allow .env.example as template
!.env.example

# ---- Next.js ----
.next/
out/
build/
.vercel

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Testing ----
coverage/
.nyc_output

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS Generated Files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- IDE / Editor ----
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ---- Certificates/Keys ----
*.pem
*.key
*.cert
*.crt

# ---- Docker ----
# Don't ignore Dockerfile and docker-compose (they're config, not secrets)

# ---- Database Dumps / Sensitive Data ----
*.sql.dump
*.db
*.sqlite
**/db_ids.json

# ---- Telegram Bot Sensitive Files ----
**/webhook.json
**/webhook_info.json

# ---- Compiled Output ----
dist/
*.js.map

# ---- Temporary / Cache ----
.cache/
.temp/
tmp/
