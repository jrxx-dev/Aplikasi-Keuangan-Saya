# ============================================
# 💰 Finance App - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Node.js
NODE_TLS_REJECT_UNAUTHORIZED=0

# ---- Database Configuration ----
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/postgres?sslmode=require
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Drizzle ORM Database ----
DATABASE_URL_DRIZLE_ORM="postgresql://postgres.your-project:your_password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"

# ---- Supabase Admin (Service Role) ----
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- AI / OpenRouter ----
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
