# ============================================
# 💰 Finance App - .gitignore
# ============================================

# ---- Dependencies ----
node_modules/

# ---- Environment Variables ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# ---- Next.js ----
.next/
out/
build/
.vercel

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Drizzle ----
drizzle/meta/

# ---- Testing ----
coverage/

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE ----
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# ---- Certificates ----
*.pem
*.key

# ---- Sensitive Data ----
db_ids.json

# ---- Docker ----
docker/postgres/data/

# ---- Compiled Output ----
dist/
*.js.map
