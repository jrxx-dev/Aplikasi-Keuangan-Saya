# ============================================
# 📊 Main Dashboard - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# ---- Database Configuration ----
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Drizzle ORM Database ----
DATABASE_URL_DRIZLE_ORM="postgresql://postgres.your-project:your_password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"
